# ─── Next.js app (deploy to Vercel) ───────────────────────────────────────────

# URL of your standalone Socket.IO server (Render / Railway / Fly.io)
# During local dev, run socket-server separately: cd socket-server && npm start
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ─── Socket Server (deploy to Render/Railway/Fly) ─────────────────────────────
# Set ALLOWED_ORIGIN to your Vercel app URL so CORS is locked down
# ALLOWED_ORIGIN=https://your-app.vercel.app
